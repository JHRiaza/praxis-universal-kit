{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRAXIS Sprint Metrics Schema v0.2",
  "description": "Sprint-level metrics for PRAXIS quasi-experiment. Supports 2x2 factorial design (Model x Structure) and L1-R observations.",
  "type": "object",
  "required": [
    "id",
    "timestamp",
    "participant_id",
    "condition",
    "task",
    "duration_minutes",
    "quality_self"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique sprint identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the sprint was logged"
    },
    "participant_id": {
      "type": "string",
      "description": "Anonymized participant ID (generated by kit)"
    },
    "condition": {
      "type": "string",
      "enum": [
        "A1",
        "A2",
        "B1",
        "B2"
      ],
      "description": "Experimental condition: A=unstructured, B=PRAXIS-lite; 1=Sonnet, 2=Opus"
    },
    "phase": {
      "type": "string",
      "enum": [
        "A",
        "B"
      ],
      "description": "Observation phase (A=passive, B=structured)"
    },
    "task": {
      "type": "string",
      "description": "What was accomplished"
    },
    "model_executor": {
      "type": "string",
      "description": "AI model used (free text)"
    },
    "model_orchestrator": {
      "type": "string",
      "description": "Model orchestrating (if multi-agent)"
    },
    "duration_minutes": {
      "type": "integer",
      "minimum": 1,
      "description": "Duration in minutes"
    },
    "iterations": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of AI generation cycles"
    },
    "quality_self": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Self-rated quality (1-5)"
    },
    "quality_external": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "External evaluator quality score (PRAXIS-Q)"
    },
    "quality_evaluator_id": {
      "type": "string",
      "description": "ID of external evaluator (for blind review tracking)"
    },
    "human_interventions": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of human corrections/overrides"
    },
    "autonomous": {
      "type": "boolean",
      "description": "Did AI complete without human help? (derived: interventions==0)"
    },
    "corrections": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of corrections applied"
    },
    "first_attempt": {
      "type": "boolean",
      "description": "Was the first output accepted?"
    },
    "praxis_layer": {
      "type": "string",
      "enum": [
        "L1",
        "L1-R",
        "L2",
        "L3",
        "L4",
        "L5"
      ],
      "description": "Dominant PRAXIS layer"
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Artifacts produced"
    },
    "l1r_observations": {
      "type": "object",
      "description": "L1-R Relational governance observations (v0.2)",
      "properties": {
        "perceived_confidence": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7,
          "description": "How confident did the AI seem? (Likert 1-7)"
        },
        "perceived_warmth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7,
          "description": "How warm/supportive did the AI feel? (Likert 1-7)"
        },
        "trust_willingness": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7,
          "description": "Would you follow this AI's advice without verifying? (Likert 1-7)"
        },
        "skepticism_activation": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7,
          "description": "Did you feel the need to verify independently? (Likert 1-7)"
        },
        "perceived_authority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7,
          "description": "How expert did the AI seem? (Likert 1-7)"
        },
        "compliance_tendency": {
          "type": "boolean",
          "description": "Did you accept the AI's output without questioning?"
        },
        "personality_mismatch": {
          "type": "boolean",
          "description": "Did the AI's behavior differ from what SOUL_TEMPLATE specified?"
        },
        "personality_mismatch_notes": {
          "type": "string",
          "description": "Description of any mismatch observed"
        }
      }
    },
    "governance_events": {
      "type": "array",
      "description": "Governance emergence events",
      "items": {
        "type": "object",
        "properties": {
          "event_type": {
            "type": "string",
            "enum": [
              "rule_created",
              "rule_modified",
              "rule_pruned",
              "incident",
              "escalation"
            ]
          },
          "description": {
            "type": "string"
          },
          "root_cause": {
            "type": "string"
          },
          "new_rule": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "incident_category": {
            "type": "string",
            "enum": [
              "OPS",
              "GOV",
              "COM",
              "PRD",
              "RES",
              "DES"
            ],
            "description": "Optional incident domain. DES is used for design, writing, and game-design failures."
          }
        }
      }
    },
    "session_boundary": {
      "type": "object",
      "description": "Session boundary observation (if applicable)",
      "properties": {
        "memory_recovery": {
          "type": "string",
          "enum": [
            "instant",
            "partial",
            "lost"
          ],
          "description": "How quickly did stored memory recover across session boundary?"
        },
        "calibration_recovery": {
          "type": "string",
          "enum": [
            "immediate",
            "gradual",
            "significant_degradation"
          ],
          "description": "How well did execution calibration recover?"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "iteration_type": {
      "type": "string",
      "enum": [
        "implementation",
        "debug",
        "refactor",
        "research",
        "design_cycle",
        "playtest",
        "revision",
        "refinement"
      ],
      "description": "Optional subtype of iteration. Supports both software and creative/design cycles."
    },
    "design_quality": {
      "type": "object",
      "description": "Creative/design quality sub-metrics inspired by tabletop and game design evaluation.",
      "properties": {
        "clarity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "How clearly rules, content, or design intent are communicated."
        },
        "tension": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "How much meaningful friction, stakes, or dramatic pull the work creates."
        },
        "balance": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "How well the system or piece avoids dominant strategies or lopsided outcomes."
        },
        "elegance": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "How efficiently the design achieves its goals without unnecessary complexity."
        },
        "notes": {
          "type": "string",
          "description": "Optional note explaining the design-quality scores."
        }
      }
    },
    "reviewer_feedback": {
      "type": "object",
      "description": "Optional external evaluation notes, useful for playtests, editorial review, and design critique.",
      "properties": {
        "reviewer_id": {
          "type": "string",
          "description": "Identifier for the reviewer or playtester."
        },
        "source": {
          "type": "string",
          "description": "Origin of feedback, e.g. playtest, editor, art director."
        },
        "summary": {
          "type": "string",
          "description": "High-level summary of the external review."
        },
        "action_items": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Concrete changes requested by the reviewer."
        },
        "sentiment": {
          "type": "string",
          "enum": [
            "positive",
            "mixed",
            "negative"
          ],
          "description": "Optional overall sentiment of the feedback."
        }
      }
    }
  }
}
